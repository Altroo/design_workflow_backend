# Basic config
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
POSTGRES_DB=design_workflow_db
POSTGRES_USER=design_workflow_user
POSTGRES_PASSWORD=design_workflow_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Local
API_URL=http://127.0.0.1:8004
FRONTEND_URL=http://localhost:3005
EBH_SSO_APP_SLUG=design_workflow
EBH_SSO_VERIFY_URL=http://localhost:8006/api/account/sso/verify/
EBH_SSO_SHARED_SECRET=development-ebh-sso-secret
# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Security (dev overrides)
SECURE_SSL_REDIRECT=False

